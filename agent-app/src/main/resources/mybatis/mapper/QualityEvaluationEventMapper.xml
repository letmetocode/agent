<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.getoffer.infrastructure.dao.QualityEvaluationEventDao">

    <resultMap id="BaseResultMap" type="com.getoffer.infrastructure.dao.po.QualityEvaluationEventPO">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="plan_id" property="planId" jdbcType="BIGINT"/>
        <result column="task_id" property="taskId" jdbcType="BIGINT"/>
        <result column="execution_id" property="executionId" jdbcType="BIGINT"/>
        <result column="evaluator_type" property="evaluatorType" jdbcType="VARCHAR"/>
        <result column="experiment_key" property="experimentKey" jdbcType="VARCHAR"/>
        <result column="experiment_variant" property="experimentVariant" jdbcType="VARCHAR"/>
        <result column="schema_version" property="schemaVersion" jdbcType="VARCHAR"/>
        <result column="score" property="score" jdbcType="DOUBLE"/>
        <result column="is_pass" property="pass" jdbcType="BOOLEAN"/>
        <result column="feedback" property="feedback" jdbcType="VARCHAR"/>
        <result column="payload" property="payload" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, plan_id, task_id, execution_id, evaluator_type, experiment_key, experiment_variant,
        schema_version, score, is_pass, feedback, payload, created_at
    </sql>

    <insert id="insert" parameterType="com.getoffer.infrastructure.dao.po.QualityEvaluationEventPO"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO quality_evaluation_events (
            plan_id, task_id, execution_id, evaluator_type, experiment_key, experiment_variant,
            schema_version, score, is_pass, feedback, payload, created_at
        ) VALUES (
            #{planId}, #{taskId}, #{executionId}, #{evaluatorType}, #{experimentKey}, #{experimentVariant},
            #{schemaVersion}, #{score}, #{pass}, #{feedback}, #{payload}::jsonb, CURRENT_TIMESTAMP
        )
    </insert>

    <select id="selectByPlanId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM quality_evaluation_events
        WHERE plan_id = #{planId}
        ORDER BY created_at DESC, id DESC
        LIMIT #{limit}
    </select>

</mapper>
