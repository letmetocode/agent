# ---------------------------
# Compose project
# ---------------------------
COMPOSE_PROJECT_NAME=agent-local
TZ=Asia/Shanghai

# ---------------------------
# PostgreSQL
# ---------------------------
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_DB=agent_db
POSTGRES_USER=agent
POSTGRES_PASSWORD=please-change-this
POSTGRES_HOST_PORT=15432

# ---------------------------
# pgAdmin (ops-ui profile)
# ---------------------------
PGADMIN_IMAGE=dpage/pgadmin4:8.14
PGADMIN_DEFAULT_EMAIL=admin@getoffer.com
PGADMIN_DEFAULT_PASSWORD=please-change-this
PGADMIN_HOST_PORT=5050

# ---------------------------
# Redis
# ---------------------------
# 当前用于缓存能力预留；截至 2026-02 主业务链路（会话/规划/执行/SSE）未依赖 Redis
REDIS_IMAGE=redis:7.2-alpine
REDIS_PASSWORD=please-change-this
REDIS_HOST_PORT=16379

# ---------------------------
# Redis Commander (ops-ui profile)
# ---------------------------
# 仅用于预留 Redis 的可视化运维
REDIS_COMMANDER_IMAGE=spryker/redis-commander:0.8.0
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=please-change-this
REDIS_COMMANDER_HOST_PORT=8081

# ---------------------------
# App container
# ---------------------------
APP_IMAGE=agent-app:local
APP_HOST_PORT=8091
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8091
DB_HOST=postgres
DB_PORT=5432
DB_NAME=agent_db
DB_USERNAME=agent
DB_PASSWORD=please-change-this

# ---------------------------
# LLM provider
# ---------------------------
OPENAI_API_KEY=a94406f9-86d4-4927-bd4d-f3c7bea874da
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com
OPENAI_MODEL=gpt-4o-mini
OPENAI_CHAT_COMPLETIONS_PATH=/api/v3/chat/completions
# Root 规划软超时（毫秒），生产建议 30000~60000
PLANNER_ROOT_TIMEOUT_SOFT_MS=30000

# ---------------------------
# App security
# ---------------------------
APP_AUTH_LOCAL_USERNAME=admin
APP_AUTH_LOCAL_PASSWORD=please-change-this
APP_AUTH_LOCAL_DISPLAY_NAME=Operator
APP_AUTH_TOKEN_TTL_HOURS=24
APP_AUTH_JWT_ISSUER=agent-app
APP_AUTH_JWT_ACCESS_TTL_MINUTES=0
APP_AUTH_JWT_SECRET=please-change-this
APP_SHARE_BASE_URL=http://127.0.0.1:8091
APP_SHARE_TOKEN_SALT=please-change-this

# ---------------------------
# JVM
# ---------------------------
JAVA_OPTS=-XX:MaxRAMPercentage=75 -XX:+UseG1GC -Dfile.encoding=UTF-8
